# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/auth_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_CODE_EXPIRE_SECONDS=60
INTERNAL_SERVICE_KEY=change-me-in-production

# Password reset email
SERVICE_PUBLIC_BASE_URL=http://localhost:8000
PASSWORD_RESET_LINK_PATH=/ui/reset-password
EMAIL_ENABLED=False
EMAIL_FROM=noreply@egs.local
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEV_EMAIL_TEST_ENABLED=False

# Rate limiting
RATE_LIMIT_LOGIN=20/minute
RATE_LIMIT_FORGOT_PASSWORD=10/minute
RATE_LIMIT_RESET_PASSWORD=10/minute
RATE_LIMIT_EXCHANGE_CODE=40/minute
RATE_LIMIT_VERIFY=120/minute
RATE_LIMIT_UI_LOGIN=20/minute
RATE_LIMIT_UI_REGISTER=10/minute

# Service Configuration
ENVIRONMENT=development
DEBUG=False
LOG_LEVEL=info

# IdP / Redirect Settings
ALLOWED_REDIRECT_ORIGINS=http://localhost:3000
AUTH_CLIENTS_JSON={"flash-sale": ["http://localhost:3000/callback"], "payment": ["http://localhost:3001/callback"]}
SSO_COOKIE_NAME=egs_sso
SSO_COOKIE_DOMAIN=
SSO_COOKIE_SECURE=False
SSO_COOKIE_SAMESITE=lax

# Production notes:
# - Set ENVIRONMENT=production
# - Use strong SECRET_KEY and INTERNAL_SERVICE_KEY values
# - Use only HTTPS domains for ALLOWED_REDIRECT_ORIGINS and AUTH_CLIENTS_JSON
# - Set SSO_COOKIE_SECURE=True
# - Keep DEV_EMAIL_TEST_ENABLED=False in shared/integration environments
