# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/auth_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_SERVICE_KEY=change-me-in-production

# Password reset & email delivery
# Set this to where your frontend UI is hosted.
SERVICE_PUBLIC_BASE_URL=http://localhost:5500
PASSWORD_RESET_LINK_PATH=/templates/reset_password.html

# SMTP defaults for local development.
# For real email delivery, replace values with your provider credentials.
EMAIL_ENABLED=False
EMAIL_FROM=noreply@egs.local
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False

# Rate limiting
RATE_LIMIT_LOGIN=20/minute
RATE_LIMIT_FORGOT_PASSWORD=10/minute
RATE_LIMIT_RESET_PASSWORD=10/minute
RATE_LIMIT_VERIFY=120/minute

# Service Configuration
ENVIRONMENT=development
DEBUG=False
LOG_LEVEL=info

# IdP / Redirect Settings
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000,null

# Production notes:
# - Set ENVIRONMENT=production
# - Use strong SECRET_KEY and INTERNAL_SERVICE_KEY values
# - Use only HTTPS domains for BACKEND_CORS_ORIGINS

# Real Email Setup (replace the SMTP values above)
# Example for Gmail:
# EMAIL_ENABLED=True
# EMAIL_FROM=your.email@gmail.com
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=your.email@gmail.com
# EMAIL_PASSWORD=your_16_char_app_password
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
